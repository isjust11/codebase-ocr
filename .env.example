# ── RabbitMQ (khớp với codebase-admin) ──────────────────────────────────────
# Khi chạy trong docker-compose, host broker là tên service "rabbitmq".
RABBITMQ_URL=amqp://smartreader:123456@localhost:5672
OCR_JOBS_QUEUE=ocr.jobs
OCR_RESULTS_QUEUE=ocr.results
OCR_EXPORT_QUEUE=ocr.export
OCR_EXPORT_RESULTS_QUEUE=ocr.export.results
OCR_DLX_QUEUE=ocr.dlx
OCR_PREFETCH=2
OCR_RMQ_HEARTBEAT=600

# ── OCR engine ───────────────────────────────────────────────────────────────
OCR_DEFAULT_LANG=vi
OCR_RENDER_DPI=240
OCR_USE_GPU=false

# ── Tách ảnh / figure / table (Phase 5b) ─────────────────────────────────────
OCR_EXTRACT_IMAGES=true
OCR_ENABLE_TABLE=true
OCR_MIN_ASSET_AREA_RATIO=0.01
OCR_DEDUP_IOU=0.6

# ── Xử lý lỗi / tiến độ ───────────────────────────────────────────────────────
OCR_MAX_RETRIES=2
OCR_PROGRESS_EVERY=1

# ── S3 (tái dùng cấu hình backend) ───────────────────────────────────────────
S3_ENDPOINT=https://s3.vn-hcm-1.vietnix.cloud
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=readbox-storage
# Tuỳ chọn: base URL public nếu khác endpoint/bucket/key (path-style).
S3_PUBLIC_BASE_URL=
OCR_S3_PREFIX=ocr/assets
OCR_S3_EXPORT_PREFIX=ocr/export

# ── Export searchable PDF ────────────────────────────────────────────────────
# Font Unicode nhúng lớp text ẩn (phủ tiếng Việt). Mặc định DejaVu trong Docker.
OCR_PDF_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf

# ── Health ─────────────────────────────────────────────────────────────────
OCR_HEALTH_PORT=8080
